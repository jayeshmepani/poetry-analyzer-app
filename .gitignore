# =============================================================================
# Poetry Analyzer App - Git Ignore File
# Exclude virtual environments, secrets, build artifacts, and temporary files
# =============================================================================

# =============================================================================
# PYTHON VIRTUAL ENVIRONMENTS
# =============================================================================
.env/
venv/
ENV/
env/
.venv/
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.huggingface_cache

# =============================================================================
# IDE & EDITOR FILES
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# SECRETS & ENVIRONMENT
# =============================================================================
.env
.env.local
.env.*.local
*.key
*.pem
secrets/
credentials/

# =============================================================================
# DATABASE FILES (SQLite)
# =============================================================================
*.db
*.sqlite
*.sqlite3
poetry_analyzer.db

# =============================================================================
# BUILD & DISTRIBUTION
# =============================================================================
build/
dist/
*.egg-info/
*.egg
*.manifest
*.spec
*.so

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# =============================================================================
# LOGS & TEMPORARY FILES
# =============================================================================
*.log
logs/
temp/
tmp/
.cache/

# =============================================================================
# DOCUMENTATION BUILD
# =============================================================================
docs/_build/
docs/build/

# =============================================================================
# JUPYTER NOTEBOOKS
# =============================================================================
.ipynb_checkpoints/

# =============================================================================
# MYPY & TYPE CHECKING
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json

# =============================================================================
# PYENV & PYTHON VERSION
# =============================================================================
.python-version
.pyenv-version

# =============================================================================
# COMPILED FILES
# =============================================================================
*.c
*.cpp
*.o
*.a
*.lib
*.dll
*.dylib

# =============================================================================
# NODE MODULES (if using any JS build tools)
# =============================================================================
node_modules/
npm-debug.log
yarn-error.log

# =============================================================================
# KEEP THESE (Examples/Documentation)
# =============================================================================
# !.env.example
# !requirements.txt
# !README.md
