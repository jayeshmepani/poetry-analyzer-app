# Poetry Analyzer App - Environment Configuration
# Copy this file to .env and update with your settings

# App Settings
APP_NAME="Poetry Analyzer"
VERSION="3.0.0"
DEBUG=true
SECRET_KEY="your-secret-key-change-in-production"

# Database Configuration
# Dedicated environment variables for seamless database switching
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=poetry_analyzer
DB_USERNAME=root
DB_PASSWORD=

# CORS Settings
CORS_ORIGINS=["http://localhost:9000","http://localhost:8000","http://127.0.0.1:9000"]

# NLP Model Settings
SPACY_ENGLISH_MODEL="en_core_web_trf"
SPACY_MULTILINGUAL_MODEL="xx_sent_ud_sm"

TRANSFORMER_SENTIMENT_MODEL="siebert/sentiment-roberta-large-english"
TRANSFORMER_EMOTION_MODEL="duelker/samo-goemotions-deberta-v3-large"

TRANSFORMER_ENGLISH_LANGUAGE_CODES='["en","en_old","en_middle","en_modern"]'
TRANSFORMER_MULTILINGUAL_SENTIMENT_MODEL="cardiffnlp/twitter-xlm-roberta-base-sentiment"
TRANSFORMER_MULTILINGUAL_EMOTION_MODEL="MoritzLaurer/DeBERTa-v3-large-mnli-fever-anli-ling-wanli"
TRANSFORMER_MULTILINGUAL_SENTIMENT_LABEL_MAP='{"LABEL_0":"NEGATIVE","LABEL_1":"NEUTRAL","LABEL_2":"POSITIVE","negative":"NEGATIVE","neutral":"NEUTRAL","positive":"POSITIVE"}'
TRANSFORMER_MULTILINGUAL_EMOTION_LABELS='["joy","sadness","anger","fear","surprise","disgust","love","neutral"]'

TRANSFORMER_INDIC_LANGUAGE_CODES='["hi","hi_braj","hi_awadhi","hi_maithili","hi_sadhukkari","hi_khariboli","gu","gu_kathiawadi","gu_charotari","gu_surati","gu_old","ur","ur_standard","ur_dakhni","ur_rekhta","ur_dhakaiya","hinglish"]'
TRANSFORMER_INDIC_SENTIMENT_MODEL="cardiffnlp/twitter-xlm-roberta-base-sentiment"
TRANSFORMER_INDIC_EMOTION_MODEL="MoritzLaurer/DeBERTa-v3-large-mnli-fever-anli-ling-wanli"
TRANSFORMER_INDIC_EMOTION_MODE="zero-shot-classification"

TRANSFORMER_GENERALIST_ZERO_SHOT_MODEL="MoritzLaurer/DeBERTa-v3-large-mnli-fever-anli-ling-wanli"
TRANSFORMER_GENERALIST_SENTIMENT_LABELS='["positive","neutral","negative"]'

STANZA_RESOURCES_DIR=".stanza_cache"
STANZA_LANGUAGES='["en","hi","gu","ur"]'
STANZA_PROCESSORS="tokenize,pos,lemma,depparse"

# Lexical & Phonology Resources
IWN_DATA_DIR=".iwn_data"
URDU_G2P_DATASET="humairmunirawn/UrduG2P"
URDU_G2P_SPLIT="train"
URDU_G2P_CACHE_DIR=".urdu_g2p_cache"
WIKTRA_CACHE_DIR=".wiktra_cache"

# Touchstone corpus (dynamic, no hardcoded passages)
TOUCHSTONE_CORPUS="gutenberg"
TOUCHSTONE_MAX_PASSAGES=4


HF_HOME=e:\project\poetry-analyzer-app\.huggingface_cache

# =============================================================================
# POST-INSTALLATION
# =============================================================================
# Required spaCy models (download after installation):
#   python -m spacy download en_core_web_trf  # English transformer (primary)
#   python -m spacy download xx_sent_ud_sm    # Multilingual (Hindi, Gujarati, Urdu, etc.)
#
# For NLTK (in Python):
#   import nltk
#   nltk.download('punkt')
#   nltk.download('averaged_perceptron_tagger')
# =============================================================================
