# Poetry Analyzer App - Environment Configuration
# Copy this file to .env and update with your settings

# App Settings
APP_NAME="Poetry Analyzer"
VERSION="3.0.0"
DEBUG=true
SECRET_KEY="your-secret-key-change-in-production"

# Database (PostgreSQL)
# Install PostgreSQL first, then create database:
#   sudo apt install postgresql
#   sudo -u postgres psql -c "CREATE DATABASE poetry_analyzer;"
#   sudo -u postgres psql -c "CREATE USER poetry_user WITH PASSWORD 'poetry_password';"
#   sudo -u postgres psql -c "GRANT ALL PRIVILEGES ON DATABASE poetry_analyzer TO poetry_user;"
#
# For development/testing without PostgreSQL, use SQLite:
DATABASE_URL="sqlite:///./poetry_analyzer.db"

# For production with PostgreSQL, use:
# DATABASE_URL="postgresql://poetry_user:poetry_password@localhost:5432/poetry_analyzer"

# CORS Settings
CORS_ORIGINS=["http://localhost:9000","http://localhost:8000","http://127.0.0.1:9000"]

# NLP Model Settings
SPACY_MODEL="en_core_web_sm"
SPACY_LOAD_TRANSFORMER=false
